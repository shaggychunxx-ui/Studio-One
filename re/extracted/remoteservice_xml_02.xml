	<!-- ******************************************************************************************** -->
	<!-- REMOTE PAGING SECTIONS -->
	<!-- ******************************************************************************************** -->

	<Sections>
		<!-- Knobs -->
		<GenericSection name="main" rows="1" columns="16">
			<foreach variable="$i" count="16">
				<Slot control="c$i.value" row="0" column="$i"/>
			</foreach>
		</GenericSection>
		<!-- Buttons -->
		<GenericSection name="mainbuttons" rows="1" columns="8">
			<Slot control="c20.value" row="0" column="0"/>
			<Slot control="c21.value" row="0" column="1"/>
			<Slot control="c22.value" row="0" column="2"/>
			<Slot control="c23.value" row="0" column="3"/>
			<Slot control="c24.value" row="0" column="4"/>
			<Slot control="c25.value" row="0" column="5"/>
			<Slot control="c26.value" row="0" column="6"/>
			<Slot control="c27.value" row="0" column="7"/>
		</GenericSection>
		<!-- XY Pad 1 -->
		<SpecialSection name="xypad">
			<Slot control="c16.value" role="x"/>
			<Slot control="c17.value" role="y"/>
		</SpecialSection>
		<!-- XY Pad 2 -->
		<SpecialSection name="xypad">
			<Slot control="c18.value" role="x"/>
			<Slot control="c19.value" role="y"/>
		</SpecialSection>
	</Sections>

	<!-- ******************************************************************************************** -->
	<!-- SURFACE MAPPINGS -->
	<!-- ******************************************************************************************** -->

	<Mappings>
	
		<!-- ******************************************************************************************** -->
        <!-- GENERIC MAPPING (used for "on the fly" control assignment) -->
        <!-- ******************************************************************************************** -->

		<GenericMapping>
			<Bank>
				<!-- Layout 1 -->
				<foreach variable="$i" count="28">	
					<Strip name="c$i.value">
						<Value control="c$i.value" param="value" options="above"/>
						<Touch control="c$i.value.edit" param="value" options="above"/>
						<String control="c$i.text" param="value"/>
						<String control="c$i.title" param="title"/>
					</Strip>
				</foreach>
				<!-- Layout 2 -->
				<foreach variable="$i" count="25">	
					<Strip name="p$i.value">
						<Value control="p$i.value" param="value" options="above"/>
						<String control="p$i.text" param="value"/>
						<String control="p$i.title" param="title"/>
					</Strip>
				</foreach>
			</Bank>
		</GenericMapping>

	</Mappings>

